# === LAUNCH ===

# Launch Rofi Application Menu
super + space
	rofi -show drun -modi drun -line-padding 4 -hide-scrollbar -show-icons -theme ~/.config/i3/rofi/config.rasi

super + v
    rofi -config ~/.config/i3/rofi/config.rasi -modi "clipboard:~/.local/bin/greenclip print" -show clipboard -run-command '~/.local/bin/greenclip print %s' && xdotool key ctrl+v

# Launch Terminal (Ghostty)
super + Return
	ghostty

# Toggle Scratchpad Terminal
super + shift + Return
	~/.config/i3/scripts/scratchpad

# Launch Browser (Firefox)
super + b
	flatpak run io.github.ungoogled_software.ungoogled_chromium

# Launch Private Browser (Firefox Incognito Mode)
super + shift + b
	flatpak run io.github.ungoogled_software.ungoogled_chromium --incognito

# Show Keybinding Help Script
super + slash
	~/.config/i3/scripts/help

# Launch File Manager (Thunar)
super + f
	thunar

# Launch Text Editor (change 'geany' to your preferred editor)
super + e
	geany

# Launch Google Lynx
super + g
	~/.config/i3/scripts/google-lynx

# Named scratchpad: audio (pulsemixer)
super + alt + a
	~/.config/i3/scripts/scratchpad pulsemixer pulsemixer

# Move current window to scratchpad
super + alt + s
	i3-msg move scratchpad

# Toggle general scratchpad
super + alt + space
	i3-msg scratchpad show

# Launch Discord
super + d
	Discord

# Launch OBS (Screen Recording/Streaming)
super + o
	obs

# === WINDOW STATE ===

# Toggle Floating
super + shift + space
	i3-msg floating toggle

# Toggle Fullscreen
super + shift + f
	i3-msg fullscreen toggle

# === WINDOW NAVIGATION ===

# Focus Left
super + h
	i3-msg focus left

# Focus Down
super + j
	i3-msg focus down

# Focus Up
super + k
	i3-msg focus up

# Focus Right
super + l
	i3-msg focus right

# Move Window Left
super + shift + h
	i3-msg move left

# Move Window Down
super + shift + j
	i3-msg move down

# Move Window Up
super + shift + k
	i3-msg move up

# Move Window Right
super + shift + l
	i3-msg move right

# Focus Left (Arrow)
super + Left
	i3-msg focus left

# Focus Down (Arrow)
super + Down
	i3-msg focus down

# Focus Up (Arrow)
super + Up
	i3-msg focus up

# Focus Right (Arrow)
super + Right
	i3-msg focus right

# Move Window Left (Arrow)
super + shift + Left
	i3-msg move left

# Move Window Down (Arrow)
super + shift + Down
	i3-msg move down

# Move Window Up (Arrow)
super + shift + Up
	i3-msg move up

# Move Window Right (Arrow)
super + shift + Right
	i3-msg move right

# === WINDOW RESIZE ===

# Resize Grow Width
super + ctrl + h
	i3-msg resize grow width 3 px or 3 ppt

# Resize Shrink Height
super + ctrl + j
	i3-msg resize shrink height 3 px or 3 ppt

# Resize Grow Height
super + ctrl + k
	i3-msg resize grow height 3 px or 3 ppt

# Resize Shrink Width
super + ctrl + l
	i3-msg resize shrink width 3 px or 3 ppt

# Resize Grow Width (Arrow)
super + ctrl + Left
	i3-msg resize grow width 3 px or 3 ppt

# Resize Shrink Height (Arrow)
super + ctrl + Down
	i3-msg resize shrink height 3 px or 3 ppt

# Resize Grow Height (Arrow)
super + ctrl + Up
	i3-msg resize grow height 3 px or 3 ppt

# Resize Shrink Width (Arrow)
super + ctrl + Right
	i3-msg resize shrink width 3 px or 3 ppt

# === LAYOUTS ===

# Layout Tabbed
super + w
	i3-msg layout tabbed

# Cycle Layout (split → tabbed → stacking)
super + t
	i3-msg layout toggle split tabbed stacking

# Cycle through tabs / siblings in current container
alt + Tab
	i3-msg focus next

alt + shift + Tab
	i3-msg focus prev

# === WM CONTROL ===

# Reload sxhkd Config
super + Escape
	pkill -USR1 -x sxhkd; notify-send 'sxhkd' 'Reloaded config'

# Reload i3 Config
super + shift + r
	i3-msg reload; notify-send 'i3' 'Reloaded'

# Exit i3
super + shift + q
	i3-msg exit

# Close Window
super + q
	i3-msg kill

