# === MEDIA & BRIGHTNESS ===

# Volume Up
super + F12
	~/.config/i3/scripts/changevolume up

# Volume Down
super + F11
	~/.config/i3/scripts/changevolume down

# Toggle Mute
super + F10
	~/.config/i3/scripts/changevolume mute

# Dedicated Key for Volume Up
XF86AudioRaiseVolume
	~/.config/i3/scripts/changevolume up

# Dedicated Key for Volume Down
XF86AudioLowerVolume
	~/.config/i3/scripts/changevolume down

# Dedicated Key for Mute
XF86AudioMute
	~/.config/i3/scripts/changevolume mute

# Brightness Up (Media Key)
XF86MonBrightnessUp
	xbacklight +10

# Brightness Down (Media Key)
XF86MonBrightnessDown
	xbacklight -10

# === SCREENSHOTS ===

# Take a Screenshot (Region Select)
super + shift + s
	flameshot gui --path ~/Screenshots/

# Take a Fullscreen Screenshot
super + s
	flameshot full --path ~/Screenshots/

# === SYSTEM ===

# Theme Switcher
super + shift + t
	~/.config/i3/scripts/thememenu

# Shutdown or Reboot
super + x
	~/.config/i3/scripts/power

XF86AudioPlay
    playerctl play-pause

XF86AudioNext
    playerctl next

XF86AudioPrev
    playerctl previous

XF86AudioStop
    playerctl stop
