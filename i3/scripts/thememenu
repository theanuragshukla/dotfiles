#!/bin/bash
# Theme switcher for i3 via rofi.
# Reads ~/.config/i3/themes/<name>/theme.conf and swaps the active palette
# (i3 colors, polybar, rofi, wezterm, ghostty, GTK + icons, wallpaper), then
# sed-substitutes color values into dunstrc. Reloads i3 + polybar.

set -u

export PATH="$HOME/.local/bin:$PATH"

I3_DIR="$HOME/.config/i3"
THEMES_DIR="$I3_DIR/themes"
AUTOSTART="$I3_DIR/scripts/autostart.sh"
WALLPAPER_DIR="$I3_DIR/wallpaper"
DUNST_CONF="$I3_DIR/dunst/dunstrc"
ROFI_DIR="$I3_DIR/rofi"
POLYBAR_COLORS="$I3_DIR/polybar/colors.ini"
GHOSTTY_CONF="$HOME/.config/ghostty/config.ghostty"
WEZTERM_CONF="$HOME/.config/wezterm/wezterm.lua"
GTK3_CONF="$HOME/.config/gtk-3.0/settings.ini"
XSETTINGSD_CONF="$HOME/.xsettingsd"
STATE="$I3_DIR/.current_theme"

# --- helpers ---

cfg_get() {
    awk -v k="$2" '
        $0 !~ /^[[:space:]]*#/ {
            n = index($0, "=")
            if (n > 0) {
                key = substr($0, 1, n-1); val = substr($0, n+1)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", key)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
                if (key == k) { print val; exit }
            }
        }' "$1"
}

# --- main ---

# Discover themes (subdirs with a theme.conf)
themes=()
for d in "$THEMES_DIR"/*/; do
    [ -f "$d/theme.conf" ] && themes+=("$(basename "$d")")
done
if [ ${#themes[@]} -eq 0 ]; then
    notify-send "i3 theme" "No themes found in $THEMES_DIR" -u critical
    exit 1
fi

current=$(cat "$STATE" 2>/dev/null || echo "github_dark")

# Build display-name → dir-name menu from each theme's `name = ...` line
declare -A name_to_dir
menu=""
for t in $(printf '%s\n' "${themes[@]}" | sort); do
    display=$(cfg_get "$THEMES_DIR/$t/theme.conf" name)
    display=${display:-$t}
    name_to_dir["$display"]="$t"
    menu+="$display"$'\n'
done

chosen=$(printf '%s' "$menu" | rofi -dmenu -i -p "Theme ($current)" -theme "$ROFI_DIR/config.rasi")
[ -z "$chosen" ] && exit 0

target="${name_to_dir[$chosen]:-}"
if [ -z "$target" ]; then
    notify-send "i3 theme" "Unknown theme: $chosen" -u critical
    exit 1
fi

dir="$THEMES_DIR/$target"
CONF="$dir/theme.conf"

if [ "$current" = "$target" ]; then
    notify-send "i3 theme" "Already using $chosen" -u low -t 1500
    exit 0
fi

# 1. i3 colors include
cp "$dir/colors.conf" "$I3_DIR/colors.conf"

# 2. Polybar colors
cp "$dir/colors.ini" "$POLYBAR_COLORS"

# 3. Rofi color palette
cp "$dir/colors.rasi" "$ROFI_DIR/colors.rasi"

# 4. Wallpaper
wp=$(cfg_get "$CONF" wallpaper)
if [ -n "$wp" ] && [ -f "$WALLPAPER_DIR/$wp" ]; then
    feh --bg-fill "$WALLPAPER_DIR/$wp"
    sed -i "s|feh --bg-fill.*|feh --bg-fill $WALLPAPER_DIR/$wp \&|" "$AUTOSTART" 2>/dev/null
fi

# 5. Ghostty
ghostty=$(cfg_get "$CONF" ghostty)
if [ -n "$ghostty" ] && [ -f "$GHOSTTY_CONF" ]; then
    if grep -q '^theme = ' "$GHOSTTY_CONF"; then
        sed -i "s|^theme = .*|theme = ${ghostty}|" "$GHOSTTY_CONF"
    else
        sed -i "1i theme = ${ghostty}" "$GHOSTTY_CONF"
    fi
    pkill -USR2 ghostty 2>/dev/null || true
fi

# 6. Wezterm (auto-reloads on file change)
wezterm=$(cfg_get "$CONF" wezterm)
if [ -n "$wezterm" ] && [ -f "$WEZTERM_CONF" ]; then
    sed -i "s|^config\.color_scheme[[:space:]]*=.*|config.color_scheme = \"${wezterm}\"|" "$WEZTERM_CONF"
fi

# 7. GTK + icons
gtk=$(cfg_get "$CONF" gtk)
icons=$(cfg_get "$CONF" icons)
if [ -f "$GTK3_CONF" ]; then
    [ -n "$gtk" ]   && sed -i "s|^gtk-theme-name=.*|gtk-theme-name=${gtk}|"             "$GTK3_CONF"
    [ -n "$icons" ] && sed -i "s|^gtk-icon-theme-name=.*|gtk-icon-theme-name=${icons}|" "$GTK3_CONF"
fi
if [ -f "$XSETTINGSD_CONF" ]; then
    [ -n "$gtk" ]   && sed -i "s|^Net/ThemeName .*|Net/ThemeName \"${gtk}\"|"             "$XSETTINGSD_CONF"
    [ -n "$icons" ] && sed -i "s|^Net/IconThemeName .*|Net/IconThemeName \"${icons}\"|"   "$XSETTINGSD_CONF"
    killall xsettingsd 2>/dev/null || true
    xsettingsd >/dev/null 2>&1 &
fi

# 8. Dunst — section-aware sed substitution
for k in frame_global bg_low fg_low frame_low highlight_low \
         bg_normal fg_normal frame_normal highlight_normal \
         bg_critical fg_critical frame_critical highlight_critical; do
    v=$(cfg_get "$CONF" "dunst_$k")
    [ -n "$v" ] && sed -i "/# THEME: dunst_$k\$/s/\"#[0-9a-fA-F]*\"/\"$v\"/" "$DUNST_CONF"
done

# 9. Persist + reload
echo "$target" > "$STATE"

polybar-msg cmd quit 2>/dev/null || true
i3-msg reload >/dev/null
~/.config/i3/polybar/polybar-i3 &

# 10. Restart dunst with new colors, then notify
pkill -x dunst 2>/dev/null || true
dunst -config "$DUNST_CONF" >/dev/null 2>&1 &
sleep 0.4
notify-send "i3 theme" "Switched to $chosen" -t 2000 -u normal
